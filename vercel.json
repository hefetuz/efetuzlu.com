{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/build-vercel.mjs",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/work/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/work/:slug/",
      "destination": "/index.html"
    }
  ]
}
