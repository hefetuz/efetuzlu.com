{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/build-vercel.mjs",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/work/hant-ai-travel-sales-deck",
      "destination": "/work/hant-motion-design/",
      "permanent": true
    },
    {
      "source": "/work/hant-ai-travel-sales-deck/",
      "destination": "/work/hant-motion-design/",
      "permanent": true
    },
    {
      "source": "/work/vita-product-design",
      "destination": "/work/vital-product-design/",
      "permanent": true
    },
    {
      "source": "/work/vita-product-design/",
      "destination": "/work/vital-product-design/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/work/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/work/:slug/",
      "destination": "/index.html"
    }
  ]
}
